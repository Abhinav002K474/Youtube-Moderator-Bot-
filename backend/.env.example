# Server Configuration
PORT=3001

# YouTube API Credentials
# Get these from https://console.cloud.google.com/
YOUTUBE_CLIENT_ID=your_google_client_id_here
YOUTUBE_CLIENT_SECRET=your_google_client_secret_here

# The redirect URI must match what you set in the Google Cloud Console
# Default for local development: http://localhost:3001/oauth2callback
YOUTUBE_REDIRECT_URI=http://localhost:3001/oauth2callback
